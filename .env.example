# Flask configuration
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key

# Redis configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password  # Uncomment if Redis requires authentication

# Message channel settings
MESSAGE_CHANNEL=intellitrans:messages
MESSAGE_HISTORY_KEY=intellitrans:history
MESSAGE_HISTORY_MAX=200
ROOM_REGISTRY_KEY=intellitrans:rooms
USER_DM_ROOMS_PREFIX=intellitrans:user_dm
DEFAULT_GROUP_ROOMS=general,tech,random

# External workflow API settings
WORKFLOW_ENABLED=true
WORKFLOW_API_URL=https://w3f64kykmn.coze.site/run
WORKFLOW_API_TOKEN=replace-with-your-token
WORKFLOW_TIMEOUT_SECONDS=5
WORKFLOW_HISTORY_WINDOW=20
WORKFLOW_FAIL_OPEN=true
